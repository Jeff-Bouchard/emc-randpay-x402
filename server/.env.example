# Emercoin RPC
EMC_HOST=127.0.0.1
EMC_PORT=6662
EMC_USER=emc
EMC_PASS=changeme

# Plan pricing (EMC, 8 decimals)
PRICE_7D=0.05000000
PRICE_30D=0.15000000

# Risk: probability server does NOT collect on a given ticket
# 7d  → 0.10  short plan, retry cost trivial, variance acceptable
# 30d → 0.03  larger value at stake, tighter tolerance
RISK_7D=0.10
RISK_30D=0.03

# CHAP validity window (seconds) — client must sign and retry within this window
TIMEOUT_7D=300
TIMEOUT_30D=300

PORT=4020
